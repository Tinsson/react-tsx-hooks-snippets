{
  "name": "react-tsx-hooks-snippets",
  "displayName": "React Tsx Hooks Snippets",
  "description": "This extension provides React, TypeScript, Hooks, Redux snippets and source reference tools for VS Code",
  "publisher": "tinsson",
  "icon": "images/logo.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:react-tsx-hooks-snippets.copyAiSourceReference"
  ],
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node compiler.js && tsc -p ./",
    "build:snippets": "node compiler.js",
    "compile": "tsc -p ./"
  },
  "version": "0.0.5",
  "engines": {
    "vscode": "^1.51.0"
  },
  "categories": [
    "Snippets"
  ],
  "contributes": {
    "commands": [
      {
        "command": "react-tsx-hooks-snippets.copyAiSourceReference",
        "title": "Copy AI Source Reference",
        "category": "AI Source Reference"
      }
    ],
    "keybindings": [
      {
        "command": "react-tsx-hooks-snippets.copyAiSourceReference",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus"
      }
    ],
    "snippets": [
      {
        "language": "typescript",
        "path": "./snippets/snippets.json"
      },
      {
        "language": "typescriptreact",
        "path": "./snippets/snippets.json"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "1.51.0",
    "typescript": "^5.8.0"
  }
}
